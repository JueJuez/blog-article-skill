# ===========================================
# AI Provider 配置
# ===========================================
# 指定使用的 AI Provider（留空则自动检测可用 Provider）
# 可选值：trae, openai, anthropic, google, local, mock
# AI_PROVIDER=trae

# OpenAI API 配置
# 获取地址：https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxx
# 可选，自定义模型，默认 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API 配置
# 获取地址：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxx
# 可选，自定义模型，默认 claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini API 配置
# 获取地址：https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=xxxx
# 可选，自定义模型，默认 gemini-2.0-flash
# GOOGLE_MODEL=gemini-2.0-flash

# 本地模型配置（Ollama、LM Studio 等）
# Ollama 默认地址：http://localhost:11434/v1
# LOCAL_API_BASE=http://localhost:11434/v1
# 可选，自定义模型，默认 llama3
# LOCAL_MODEL=llama3

# ===========================================
# 输出目标配置
# ===========================================

# Obsidian 知识库路径（可选）
# OBSIDIAN_VAULT_PATH=D:\你的Obsidian库路径

# 飞书知识库空间 ID（可选）
# FEISHU_WIKI_SPACE=你的知识库空间ID

# 飞书知识库父节点 Token（可选）
# FEISHU_WIKI_PARENT_NODE=父节点Token

# ===========================================
# Provider 自动检测优先级（自动总结用）
# ===========================================
# 1. 优先使用 AI_PROVIDER 环境变量指定的外部 Provider
# 2. 按以下顺序自动选择第一个可用的：
#    openai > anthropic > google > local
# 3. Trae SDK 不参与自动检测，归入降级流程由外层对话接手
# 4. 设置 AI_PROVIDER=trae 可强制使用 Trae SDK 子会话总结
